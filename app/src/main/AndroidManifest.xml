<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network access for model downloads -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Foreground service for WorkManager download notifications (Android 9+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Post notifications (Android 13+) — download progress -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Storage permissions for reading GGUF models from external paths -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Android 13+ granular media permissions -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:name=".LokaiApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LokAI"
        android:extractNativeLibs="true">

        <!--
            FIX (Bug 3 + Bug 8): windowSoftInputMode changed from "adjustResize" to
            "adjustNothing". The ChatScreen and AgentChatScreen now handle IME insets
            themselves via Modifier.imePadding() on the input bar composables.

            "adjustResize" combined with enableEdgeToEdge() in MainActivity causes a
            double-adjustment — Android resizes the window AND the imePadding modifier
            also shifts content, making the layout jump erratically on some devices
            (especially ColorOS / MIUI). "adjustNothing" lets Compose handle all IME
            inset adjustments cleanly via WindowInsets.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:windowSoftInputMode="adjustNothing"
            android:theme="@style/Theme.LokAI">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
             FIX: WorkManager's foreground service needs an explicit <service> declaration
             on Android 12+ (API 31+). Without this, setForeground() and setExpedited()
             throw an exception at runtime, and the download worker is killed when
             the app is backgrounded (causing the "download stops on screen switch" bug).
             android:foregroundServiceType="dataSync" matches FOREGROUND_SERVICE_DATA_SYNC
             which is already declared in the permissions block above.
        -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <!-- WorkManager initialisation provider -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup" />
        </provider>

        <!-- FileProvider — used to share exported .md conversation files -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
